// Ansible managed — local overrides for unattended-upgrades.
// Upstream recommends this pattern over editing 50unattended-upgrades.
// See: https://github.com/mvo5/unattended-upgrades#readme

// Replace the default origins list with one that includes -updates
// and -backports. #clear is required because list settings append,
// not replace.
#clear Unattended-Upgrade::Allowed-Origins;
Unattended-Upgrade::Allowed-Origins {
    "${distro_id}:${distro_codename}";
    "${distro_id}:${distro_codename}-security";
    "${distro_id}ESMApps:${distro_codename}-apps-security";
    "${distro_id}ESM:${distro_codename}-infra-security";
    "${distro_id}:${distro_codename}-updates";
    "${distro_id}:${distro_codename}-backports";
};

Unattended-Upgrade::MinimalSteps "true";
Unattended-Upgrade::Remove-Unused-Dependencies "true";
